{
  "name": "language-learning-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node tests/dev-server.mjs",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "validate": "node validation/validate-structure.js && node validation/validate-templates.js && node validation/validate-exercises.js && node validation/validate-packs.js && node validation/validate-sentences.mjs && node validation/validate-grammar-notes.mjs",
    "validate:sentences": "node validation/validate-sentences.mjs",
    "validate:sentences:update": "node validation/validate-sentences.mjs --update-baseline"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
